# =============================================================================
# Enterprise Revenue Intelligence Platform (ERIP)
# Git Ignore Rules
# =============================================================================

# -----------------------------------------------------------------------------
# Python Bytecode
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------------------------------------------------------
# Virtual Environment
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Packaging
# -----------------------------------------------------------------------------
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Python Tooling
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Local Environment Variables
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Local Databases
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp

# -----------------------------------------------------------------------------
# Generated Reports
# -----------------------------------------------------------------------------
reports/generated/
exports/
output/

# -----------------------------------------------------------------------------
# Data Files (Keep Folder Structure)
# -----------------------------------------------------------------------------
data/raw/*
data/interim/*
data/processed/*

# Keep directory structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# -----------------------------------------------------------------------------
# Generated Documentation
# -----------------------------------------------------------------------------
site/

# -----------------------------------------------------------------------------
# Power BI Cache
# -----------------------------------------------------------------------------
*.pbix.autosave

# -----------------------------------------------------------------------------
# Secrets / Certificates
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.pfx

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.pid
*.seed